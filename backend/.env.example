# Copy this file to .env and fill your own key before starting backend.

# App
SECRET_KEY=changethis
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/app

# LLM Provider: deepseek or openai
LLM_PROVIDER=deepseek

# Your API key (required)
LLM_API_KEY=sk-your-deepseek-key

# DeepSeek OpenAI-compatible endpoint
LLM_BASE_URL=https://api.deepseek.com

# Chat model
LLM_CHAT_MODEL=deepseek-chat

# Optional fallback model when the primary model is unavailable.
# Example: deepseek-chat or deepseek-reasoner
LLM_FALLBACK_CHAT_MODEL=

# Optional embedding model.
# Keep empty when using DeepSeek-only plan to fallback to non-vector retrieval behavior.
LLM_EMBEDDING_MODEL=

# Embedding provider: auto | remote | local
# - auto: use remote when EMBEDDING_API_KEY is set, otherwise lexical fallback
# - local: use local embedding model (no API key required)
EMBEDDING_PROVIDER=auto

# Optional dedicated embedding credentials (recommended when chat uses DeepSeek).
# Example (OpenAI embeddings):
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# Retrieval top-k for RAG.
RAG_RETRIEVE_TOP_K=3

# Backward compatibility only
OPENAI_API_KEY=
