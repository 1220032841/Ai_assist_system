# Copy this file to .env.online and fill values before deployment.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_db_password
POSTGRES_DB=app

# MUST change this to a long random value.
SECRET_KEY=change_this_to_a_long_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional when frontend and backend are on same domain behind nginx in this stack.
# Keep empty, or set explicit origins if you call backend from other domain.
# Examples:
# BACKEND_CORS_ORIGINS=http://your-server-ip,https://your-domain.com
BACKEND_CORS_ORIGINS=

LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_CHAT_MODEL=deepseek-chat
# Recommended full RAG mode: local embeddings inside the backend container.
LLM_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_PROVIDER=local
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
RAG_RETRIEVE_TOP_K=3
OPENAI_API_KEY=

# Optional mirrors (leave empty if not needed)
APT_MIRROR=
APT_SECURITY_MIRROR=
PIP_INDEX_URL=https://pypi.org/simple
